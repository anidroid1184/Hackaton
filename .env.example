# ==========================================
# BACKEND (FastAPI)
# ==========================================
ENVIRONMENT=dev
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,[http://127.0.0.1:5173](http://127.0.0.1:5173)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ==========================================
# SUPABASE (DB / Auth / Edge Functions)
# ==========================================
SUPABASE_URL=[https://tu-proyecto.supabase.co](https://tu-proyecto.supabase.co)
# IMPORTANTE: Service Role solo para FastAPI o Edge Functions. NUNCA exponer al frontend.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ==========================================
# FRONTEND (React / Vite)
# ==========================================
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=[https://tu-proyecto.supabase.co](https://tu-proyecto.supabase.co)
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui
